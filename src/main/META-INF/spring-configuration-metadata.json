{
  "groups": [
    {
      "name": "system.auth",
      "type": "cn.rtt.server.system.config.SystemAuthProperties",
      "sourceType": "cn.rtt.server.system.config.SystemAuthProperties"
    },
    {
      "name": "system.auth.jwt",
      "type": "cn.rtt.server.system.config.SystemAuthProperties$JwtConfig",
      "sourceType": "cn.rtt.server.system.config.SystemAuthProperties",
      "sourceMethod": "getJwt()"
    },
    {
      "name": "system.auth.login",
      "type": "cn.rtt.server.system.config.SystemAuthProperties$LoginConfig",
      "sourceType": "cn.rtt.server.system.config.SystemAuthProperties",
      "sourceMethod": "getLogin()"
    }
  ],
  "properties": [
    {
      "name": "system.auth.jwt.secret",
      "type": "java.lang.String",
      "description": "JWT secret key",
      "sourceType": "cn.rtt.server.system.config.SystemAuthProperties$JwtConfig"
    },
    {
      "name": "system.auth.jwt.private-key",
      "type": "java.lang.String",
      "description": "Private key for JWT",
      "sourceType": "cn.rtt.server.system.config.SystemAuthProperties$JwtConfig"
    },
    {
      "name": "system.auth.jwt.public-key",
      "type": "java.lang.String",
      "description": "Public key for JWT",
      "sourceType": "cn.rtt.server.system.config.SystemAuthProperties$JwtConfig"
    },
    {
      "name": "system.auth.jwt.header",
      "type": "java.lang.String",
      "description": "JWT header name",
      "sourceType": "cn.rtt.server.system.config.SystemAuthProperties$JwtConfig",
      "defaultValue": "Authorization"
    },
    {
      "name": "system.auth.jwt.access-token-ttl",
      "type": "java.time.Duration",
      "description": "Access token expiration time (e.g., 15s, 30m, 1h)",
      "sourceType": "cn.rtt.server.system.config.SystemAuthProperties$JwtConfig",
      "defaultValue": "15s"
    },
    {
      "name": "system.auth.jwt.refresh-token-ttl",
      "type": "java.time.Duration",
      "description": "Refresh token expiration time (e.g., 7d, 30d, 1h)",
      "sourceType": "cn.rtt.server.system.config.SystemAuthProperties$JwtConfig",
      "defaultValue": "7d"
    },
    {
      "name": "system.auth.login.max-retry-count",
      "type": "java.lang.Integer",
      "description": "Maximum number of login retry attempts",
      "sourceType": "cn.rtt.server.system.config.SystemAuthProperties$LoginConfig",
      "defaultValue": 5
    },
    {
      "name": "system.auth.login.lock-time",
      "type": "java.time.Duration",
      "description": "Account lock time (e.g., 5m, 10m, 1h)",
      "sourceType": "cn.rtt.server.system.config.SystemAuthProperties$LoginConfig",
      "defaultValue": "5m"
    }
  ],
  "hints": []
}